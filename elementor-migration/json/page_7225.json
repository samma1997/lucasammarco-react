      {
        "id": "atb973a",
        "elType": "widget",
        "widgetType": "text-editor",
        "settings": {
          "editor": "<p>1. Consulenza iniziale gratuita. 2. Stima e proposta. 3. Kick-off con brief dettagliato. 4. Design mockup per approvazione. 5. Sviluppo e testing. 6. Lancio e training.</p>",
          "_animation": "fadeIn",
