        "elements": []
      },
      {
        "id": "v384q5b",
        "elType": "widget",
        "widgetType": "text-editor",
        "settings": {
          "editor": "<p>SEO è incluso nel setup base (titoli, meta, heading structure, URL). Per SEO avanzato (keyword strategy, content planning, link building): €500-2000 extra.</p>",
          "_animation": "fadeIn",
          "typography_typography": "custom",
          "typography_font_family": "Work Sans"
        },
        "elements": []
      },
      {
