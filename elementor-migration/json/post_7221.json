      {
        "id": "fe6jtid",
        "elType": "widget",
        "widgetType": "text-editor",
        "settings": {
          "editor": "<p>La scelta della piattaforma è fondamentale quando decidi come <strong>creare un sito web</strong>. Esistono diverse opzioni, ognuna con pro e contro:</p>",
          "_animation": "fadeIn",
          "typography_typography": "custom",
